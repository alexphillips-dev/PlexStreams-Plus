<script async>
$(function() {
    // append data from the table into the correct one
    $("#db-box<?php echo $dashboard_widget_pos ?>").append($(".dash_plexstreamsplus").html());

    // reload toggle to get the correct state
    toggleView('dash_plexstreamsplus_toggle',true);

    // reload sorting to get the stored data (cookie)
    sortTable($('#db-box1'),$.cookie('db-box1'));
    sortTable($('#db-box2'),$.cookie('db-box2'));
    sortTable($('#db-box3'),$.cookie('db-box3'));

    plexStreamsPlusStartPolling('dashboard_legacy', function() {
        return updateDashboardStreams('dashboard_legacy');
    });
});
</script>
